# ─── AI provider ─────────────────────────────────────────────
# Required: pick one of gemini | claude | openai | openrouter | ollama
AI_PROVIDER=gemini

# Required for all providers except ollama
AI_API_KEY=

# Optional — falls back to per-provider default when unset:
#   gemini     → gemini-3.1-flash
#   claude     → claude-haiku-4-5
#   openai     → gpt-4o-mini
#   openrouter → google/gemini-2.5-flash
#   ollama     → llama3.1
# AI_MODEL=

# Optional — custom endpoint. Leave blank for provider default.
#   ollama example: http://localhost:11434/v1
#   openrouter is auto-set; override only if you use a proxy.
# AI_BASE_URL=


# ─── Data ────────────────────────────────────────────────────
# Where your markdown notes live. Relative paths resolve against the
# working directory. The recommended setup is an independent git repo
# containing your notes — see docs/data-management.md.
# DATA_DIR=./data

# Optional — persistent AI cache location. Defaults to DATA_DIR/cache.
# CACHE_DIR=


# ─── Server ──────────────────────────────────────────────────
# URL prefix the app is mounted under. Matches the `base` in
# frontend/vite.config.ts — change both if you need a different prefix.
BASE_PATH=mind-vault

# Port exposed by docker-compose (container always listens on 10016)
PORT=10016
